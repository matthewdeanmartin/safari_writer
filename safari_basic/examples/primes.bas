10 REM -- Prime Number Sieve --
20 PRINT "PRIME NUMBERS UP TO 100:"
30 DIM P(100)
40 FOR I = 2 TO 100
50 P(I) = 1
60 NEXT I
70 FOR I = 2 TO 10
80 IF P(I) = 0 THEN GOTO 120
90 FOR J = I TO 100 STEP I
100 IF J > I THEN P(J) = 0
110 NEXT J
120 NEXT I
130 FOR I = 2 TO 100
140 IF P(I) = 1 THEN PRINT I
150 NEXT I
160 PRINT
170 END
